# ── Supabase ─────────────────────────────────────────────
# From the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used by privileged server actions.
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (MCP / CLI — added when you share MCP access) ─
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# ── AI (Vercel AI Gateway) ───────────────────────────────
AI_GATEWAY_API_KEY=

# ── Messaging (added in the notifications step) ──────────
SMS_PROVIDER_KEY=
WHATSAPP_TOKEN=

# ── App secrets ──────────────────────────────────────────
OTP_SECRET=
CRON_SECRET=

# ── App config ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
